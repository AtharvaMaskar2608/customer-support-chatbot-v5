# Database — single connection string (psycopg v3 / pgvector)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic (agent model)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (embeddings for RAG)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-large

# DeepEval / Confident AI tracing (optional — no-op when unset)
CONFIDENT_API_KEY=
TRACING_ENABLED=false

# FinX middleware reports — single host for /api/middleware/* and /middleware-go/*
FINX_MIDDLEWARE_BASE_URL=https://finx.choiceindia.com
